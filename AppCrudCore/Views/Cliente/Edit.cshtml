@model AppCrudCore.Models.Cliente

@{
    ViewData["Title"] = "Edit";
}

<section class="main-container">
    <div class="glass-card">
        <header class="form-header">
            <h1 class="title">Editar Cliente</h1>
            <p class="subtitle">Actualización de información de usuario y credenciales</p>
        </header>

        <div class="form-wrapper">
            <form asp-action="Edit" class="modern-form">
                <div asp-validation-summary="ModelOnly" class="error-text"></div>
                <input type="hidden" asp-for="IdCliente" />

                <div class="form-grid">
                    @* Datos Personales *@
                    <div class="input-group">
                        <label asp-for="Cedula" class="field-label"></label>
                        <input asp-for="Cedula" class="custom-input" placeholder="0-0000-0000" />
                        <span asp-validation-for="Cedula" class="error-text"></span>
                    </div>

                    <div class="input-group">
                        <label asp-for="NombreCompleto" class="field-label"></label>
                        <input asp-for="NombreCompleto" class="custom-input" />
                        <span asp-validation-for="NombreCompleto" class="error-text"></span>
                    </div>

                    <div class="input-group">
                        <label asp-for="Correo" class="field-label"></label>
                        <input asp-for="Correo" class="custom-input" type="email" />
                        <span asp-validation-for="Correo" class="error-text"></span>
                    </div>

                    <div class="input-group">
                        <label asp-for="Telefono" class="field-label"></label>
                        <input asp-for="Telefono" class="custom-input" />
                        <span asp-validation-for="Telefono" class="error-text"></span>
                    </div>

                    <div class="input-group">
                        <label asp-for="FechaRegistro" class="field-label"></label>
                        <input asp-for="FechaRegistro" class="custom-input" readonly />
                        <span asp-validation-for="FechaRegistro" class="error-text"></span>
                    </div>

                    <div class="input-group">
                        <label asp-for="RolId" class="field-label">Rol del Usuario</label>
                        <select asp-for="RolId" class="custom-select" asp-items="ViewBag.RolId"></select>
                        <span asp-validation-for="RolId" class="error-text"></span>
                    </div>
                </div>

                <div class="input-group">
                    <label asp-for="Direccion" class="field-label"></label>
                    <textarea asp-for="Direccion" class="custom-input" rows="2"></textarea>
                    <span asp-validation-for="Direccion" class="error-text"></span>
                </div>

                <div class="separator"></div>

                @* Seguridad y Estado *@
                <div class="form-grid">
                    <div class="input-group">
                        <label asp-for="PasswordHash" class="field-label">Contraseña (Hash)</label>
                        <input asp-for="PasswordHash" class="custom-input" type="password" />
                        <span asp-validation-for="PasswordHash" class="error-text"></span>
                    </div>

                    <div class="input-group" style="justify-content: center; gap: 10px; flex-direction: row; align-items: center; padding-top: 25px;">
                        <div class="custom-checkbox-wrapper">
                            <input class="form-check-input" asp-for="PasswordTemp" />
                            <label class="field-label" style="margin-bottom: 0;">@Html.DisplayNameFor(model => model.PasswordTemp)</label>
                        </div>
                        <div class="custom-checkbox-wrapper">
                            <input class="form-check-input" asp-for="Activo" />
                            <label class="field-label" style="margin-bottom: 0;">@Html.DisplayNameFor(model => model.Activo)</label>
                        </div>
                    </div>
                </div>

                <div class="actions">
                    <button type="submit" class="btn-primary-submit">Guardar Cambios</button>
                    <a asp-action="Index" class="btn-back">Cancelar y Regresar</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}