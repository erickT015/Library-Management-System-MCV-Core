@model ErrorViewModel
@{
    ViewData["Title"] = "Error del sistema";
}

<section class="system-error-page">

    <div class="error-content">

        <div class="error-symbol">
            ✕
        </div>

        <h1 class="error-title">
            No fue posible procesar la solicitud
        </h1>

        <p class="error-message">
            Ocurrió un error inesperado mientras el sistema
            intentaba completar la operación.
        </p>

        <p class="error-sub">
            Intente nuevamente más tarde o contacte
            al administrador si el problema persiste.
        </p>

        @if (Model?.RequestId != null)
        {
            <div class="error-trace">
                Código de incidente:
                <span>@Model.RequestId</span>
            </div>
        }

        <div class="error-actions">
            <button onclick="history.back()" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">
                < Regresar
            </button>
        </div>

    </div>

</section>