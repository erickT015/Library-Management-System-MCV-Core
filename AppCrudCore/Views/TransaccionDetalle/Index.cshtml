@model IEnumerable<AppCrudCore.Models.TransaccionDetalle>

@{
    ViewData["Title"] = "Index";
}

<section class="main-container">
    <div class="glass-card table-page">
        <header class="table-header">
            <div class="header-content">
                <h1 class="title">Detalles Transacción</h1>
                <p class="subtitle">Visualice los detalles de transacciones</p>
            </div>
            <a asp-action="Create" class="btn-create"> agregar Libro</a>
        </header>

        <div class="table-responsive">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.TransaccionBiblioteca)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Libro)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Cantidad)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.PrecioUnitario)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Subtotal)
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.TransaccionBiblioteca.IdTransaccionBiblioteca)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Libro.Autor)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Cantidad)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.PrecioUnitario)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Subtotal)
                            </td>
                            <td class="actions-cell">
                                <div class="action-buttons">
                                    <a asp-action="Edit" asp-route-id="@item.IdTransaccionDetalle">Edit</a> |
                                    <a asp-action="Details" asp-route-id="@item.IdTransaccionDetalle">Details</a> |
                                    <a asp-action="Delete" asp-route-id="@item.IdTransaccionDetalle">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
