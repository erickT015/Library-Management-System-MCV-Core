@model AppCrudCore.Models.ViewModels.Profile.ProfileIndexViewModel

<div class="profile-container">

    <div class="profile-card">

        <div class="profile-header">
            <div class="avatar">
                @Model.NombreCompleto.Substring(0, 1)
            </div>

            <h2>@Model.NombreCompleto</h2>
            <span class="role">@Model.RolNombre</span>
        </div>

        <div class="profile-info">

            <div class="info-row">
                <label>Correo</label>
                <span>@Model.Correo</span>
            </div>

            <div class="info-row">
                <label>Cédula</label>
                <span>@Model.Cedula</span>
            </div>

            <div class="info-row">
                <label>Teléfono</label>
                <span>@Model.Telefono</span>
            </div>

            <div class="info-row">
                <label>Dirección</label>
                <span>@Model.Direccion</span>
            </div>

            <div class="info-row">
                <label>Último acceso</label>
                <span>@Model.UltimoLogin</span>
            </div>

        </div>

        <div class="profile-actions">
            <a asp-action="Edit" class="btn-primary">
                Editar Perfil
            </a>
        </div>

    </div>

</div>